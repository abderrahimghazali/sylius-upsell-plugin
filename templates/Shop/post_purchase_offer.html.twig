{# Injected into checkout complete page — intercepts Place Order with upsell modal #}
{% set order = hookable_metadata.context.order|default(null) %}
{% set orderId = order.id|default(0) %}
{# Fallback: try to get order ID from Sylius cart context #}
{% if orderId == 0 and sylius is defined and sylius.cart is defined and sylius.cart.id is defined %}
    {% set orderId = sylius.cart.id %}
{% endif %}

{% if orderId > 0 %}
    {% set offerUrl = path('abderrahim_sylius_upsell_shop_offer', {'orderId': orderId}) %}
    {% set acceptUrlBase = path('abderrahim_sylius_upsell_shop_accept', {'offerId': 0}) %}
    {% set impressionUrl = path('abderrahim_sylius_upsell_shop_impression') %}
{% endif %}

<div id="upsell-modal" class="upsell-hidden" data-adding-text="{{ 'upsell.shop.adding'|trans }}"></div>

<style>
    .upsell-hidden { display: none !important; }
    .upsell-overlay {
        position: fixed; inset: 0; z-index: 1055;
        background: rgba(0, 0, 0, 0.5);
        display: flex; align-items: center; justify-content: center;
        animation: upsellFadeIn 0.2s ease-out;
    }
    .upsell-discount-badge {
        position: absolute; top: -8px; right: -8px;
    }
    .upsell-price-original {
        text-decoration: line-through;
    }
    @keyframes upsellFadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }
    @keyframes upsellSlideUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .upsell-dialog {
        animation: upsellSlideUp 0.3s ease-out;
    }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    var OFFER_URL = '{{ offerUrl|default('')|e('js') }}';
    var ACCEPT_URL_BASE = '{{ acceptUrlBase|default('')|e('js') }}';
    var IMPRESSION_URL = '{{ impressionUrl|default('')|e('js') }}';

    if (!OFFER_URL) return;

    var modal = document.getElementById('upsell-modal');
    var form = document.querySelector('form[name="sylius_checkout_complete"]');
    var offer = null;
    var intercepted = false;

    if (!form) return;

    function esc(s) {
        var d = document.createElement('div');
        d.textContent = s || '';
        return d.innerHTML;
    }

    function formatPrice(cents, currency) {
        try {
            return new Intl.NumberFormat(document.documentElement.lang || 'en', {
                style: 'currency', currency: currency || 'USD'
            }).format(cents / 100);
        } catch(e) { return currency + ' ' + (cents / 100).toFixed(2); }
    }

    function showModal(data) {
        offer = data;
        var orig = formatPrice(data.product.originalPrice, data.product.currency);
        var disc = formatPrice(data.product.discountedPrice, data.product.currency);
        var imgUrl = data.product.imageUrl || '';
        var img = imgUrl
            ? '<img src="' + esc(imgUrl) + '" alt="' + esc(data.product.name) + '" style="width:120px;border-radius:8px" />'
            : '';
        var badge = data.discountPercent > 0
            ? '<span class="badge bg-danger rounded-pill upsell-discount-badge">-' + data.discountPercent + '%</span>'
            : '';

        modal.innerHTML =
            '<div class="upsell-overlay">' +
                '<div class="card shadow-lg border-0 upsell-dialog" style="max-width:440px;width:90%">' +
                    '<div class="card-body text-center p-4">' +
                        '<h4 class="card-title fw-bold mb-2">' + esc(data.headline) + '</h4>' +
                        (data.body ? '<p class="text-muted mb-4">' + esc(data.body) + '</p>' : '') +
                        '<div class="d-flex align-items-center justify-content-center gap-3 mb-4 flex-wrap">' +
                            '<div class="position-relative">' + img + badge + '</div>' +
                            '<div class="text-start">' +
                                '<h6 class="mb-1">' + esc(data.product.name) + '</h6>' +
                                '<div class="d-flex align-items-baseline gap-2">' +
                                    (data.discountPercent > 0 ? '<span class="text-muted upsell-price-original small">' + orig + '</span>' : '') +
                                    '<span class="fw-bold text-success fs-5">' + disc + '</span>' +
                                '</div>' +
                            '</div>' +
                        '</div>' +
                        '<div class="d-flex gap-3 justify-content-center mt-2">' +
                            '<button type="button" class="btn btn-primary px-4 py-2" id="upsell-accept">' + esc(data.ctaLabel) + '</button>' +
                            '<button type="button" class="btn btn-outline-secondary px-4 py-2" id="upsell-decline">' + esc(data.declineLabel) + '</button>' +
                        '</div>' +
                    '</div>' +
                '</div>' +
            '</div>';

        modal.classList.remove('upsell-hidden');

        document.getElementById('upsell-accept').addEventListener('click', acceptOffer);
        document.getElementById('upsell-decline').addEventListener('click', declineOffer);
    }

    function trackImpression(action, revenue) {
        if (!IMPRESSION_URL || !offer) return;
        fetch(IMPRESSION_URL, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                type: 'post_purchase',
                productCode: offer.product.variantCode,
                impressionId: offer.impressionId,
                offerId: offer.offerId,
                action: action,
                revenue: revenue || 0
            })
        }).catch(function() {});
    }

    function acceptOffer() {
        var btn = document.getElementById('upsell-accept');
        btn.disabled = true;
        var addingText = modal.getAttribute('data-adding-text') || 'Adding...';
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>' + esc(addingText);

        var url = ACCEPT_URL_BASE.replace('/0', '/' + offer.offerId);
        fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest', 'X-CSRF-Token': offer.csrfToken || '', 'X-Impression-Id': String(offer.impressionId || 0) }
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            trackImpression('accepted', data.revenue || offer.product.discountedPrice);
            modal.classList.add('upsell-hidden');
            var locale = window.location.pathname.split('/')[1] || 'en_US';
            window.location.href = '/' + locale + '/cart/';
        })
        .catch(function() { modal.classList.add('upsell-hidden'); form.submit(); });
    }

    function declineOffer() {
        trackImpression('declined', 0);
        modal.classList.add('upsell-hidden');
        form.submit();
    }

    form.addEventListener('submit', function(e) {
        if (intercepted) return;
        intercepted = true;
        e.preventDefault();

        fetch(OFFER_URL)
            .then(function(r) {
                if (!r.ok || r.status === 204) { form.submit(); return; }
                return r.json();
            })
            .then(function(data) {
                if (data) showModal(data);
                else form.submit();
            })
            .catch(function() { form.submit(); });
    });
});
</script>
