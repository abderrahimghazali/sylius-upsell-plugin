{# Injected into the thank-you page via Twig hook #}
<!-- UPSELL DEBUG: hook rendered, context keys: {{ hookable_metadata.context|keys|join(', ') }} -->
{% set orderToken = hookable_metadata.context.order.tokenValue|default('') %}
<!-- UPSELL DEBUG: orderToken={{ orderToken }} -->

{% if orderToken %}
    <div data-controller="post-purchase"
         data-post-purchase-offer-url-value="{{ path('abderrahim_sylius_upsell_shop_offer', {'orderToken': orderToken}) }}"
         data-post-purchase-accept-url-value="{{ path('abderrahim_sylius_upsell_shop_accept', {'orderToken': orderToken}) }}"
         data-post-purchase-order-token-value="{{ orderToken }}">

        <div data-post-purchase-target="container" class="hidden"></div>
    </div>

    <style>
        .upsell-offer {
            margin: 2rem 0;
            border: 2px solid #e8e8e8;
            border-radius: 12px;
            overflow: hidden;
            background: linear-gradient(135deg, #fefefe 0%, #f8f9ff 100%);
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
        }
        .upsell-offer__content {
            padding: 2rem;
            text-align: center;
        }
        .upsell-offer__headline {
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
            color: #1a1a2e;
        }
        .upsell-offer__body {
            color: #555;
            margin-bottom: 1.5rem;
        }
        .upsell-offer__product {
            display: flex;
            align-items: center;
            gap: 1.5rem;
            justify-content: center;
            margin-bottom: 1.5rem;
            flex-wrap: wrap;
        }
        .upsell-offer__product-image {
            position: relative;
            width: 150px;
            flex-shrink: 0;
        }
        .upsell-offer__product-image img {
            width: 100%;
            border-radius: 8px;
        }
        .upsell-offer__badge {
            position: absolute;
            top: 8px;
            right: 8px;
            background: #e74c3c;
            color: white;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 600;
        }
        .upsell-offer__product-name {
            font-size: 1.1rem;
            margin-bottom: 0.5rem;
        }
        .upsell-offer__pricing {
            display: flex;
            gap: 0.75rem;
            align-items: baseline;
        }
        .upsell-offer__price--original {
            text-decoration: line-through;
            color: #999;
            font-size: 0.95rem;
        }
        .upsell-offer__price--current {
            font-size: 1.25rem;
            font-weight: 700;
            color: #27ae60;
        }
        .upsell-offer__actions {
            display: flex;
            gap: 1rem;
            justify-content: center;
            flex-wrap: wrap;
        }
        .upsell-offer__cta {
            background: #206bc4;
            color: white;
            border: none;
            padding: 12px 28px;
            border-radius: 8px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.2s;
        }
        .upsell-offer__cta:hover {
            background: #1a56a0;
        }
        .upsell-offer__cta:disabled {
            opacity: 0.6;
            cursor: wait;
        }
        .upsell-offer__decline {
            background: transparent;
            border: 1px solid #ddd;
            padding: 12px 28px;
            border-radius: 8px;
            font-size: 1rem;
            cursor: pointer;
            color: #666;
            transition: border-color 0.2s;
        }
        .upsell-offer__decline:hover {
            border-color: #999;
        }
        .hidden {
            display: none !important;
        }
    </style>
{% endif %}
