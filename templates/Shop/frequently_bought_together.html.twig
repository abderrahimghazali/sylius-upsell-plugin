{% set fbtProducts = upsell_frequently_bought_together(product) %}
{% set config = upsell_configuration() %}

{% if fbtProducts|length > 0 and config.enabled %}
    <div class="ui segment"
         data-controller="abderrahimghazali--sylius-upsell-plugin--fbt"
         data-abderrahimghazali--sylius-upsell-plugin--fbt-add-to-cart-url-value="{{ path('sylius_shop_api_cart_add_item', {'tokenValue': sylius.cart.tokenValue|default('')}) }}"
         data-abderrahimghazali--sylius-upsell-plugin--fbt-token-value="{{ sylius.cart.tokenValue|default('') }}"
         data-abderrahimghazali--sylius-upsell-plugin--fbt-impression-url-value="{{ path('abderrahim_sylius_upsell_shop_impression') }}"
         data-abderrahimghazali--sylius-upsell-plugin--fbt-impression-csrf-value="{{ csrf_token('upsell_impression') }}"
         data-abderrahimghazali--sylius-upsell-plugin--fbt-product-codes-value="{{ product.code|default('') }}">

        <h3 class="ui header">
            {{ config.sectionTitle|trans }}
        </h3>

        <div class="ui stackable four column grid">
            {% for item in fbtProducts %}
                {% set fbtProduct = item.product %}
                {% set discount = item.discount %}
                {% set defaultVariant = fbtProduct.variants|first %}

                <div class="column">
                    <div class="ui fluid card">
                        {% set image = fbtProduct.imagesByType('main')|first %}
                        {% if image %}
                            <div class="image">
                                <img src="{{ image.path|imagine_filter('sylius_shop_product_thumbnail') }}"
                                     alt="{{ fbtProduct.name }}" loading="lazy"/>

                                {% if discount and config.showDiscountBadge %}
                                    <div class="ui red ribbon label">
                                        -{{ discount }}%
                                    </div>
                                {% endif %}
                            </div>
                        {% endif %}

                        <div class="content">
                            <a class="header" href="{{ path('sylius_shop_product_show', {'slug': fbtProduct.slug}) }}">
                                {{ fbtProduct.name }}
                            </a>

                            <div class="meta">
                                {% if defaultVariant %}
                                    <span class="price">
                                        {{ defaultVariant.channelPricings.first.price|sylius_format_money(sylius.channel.baseCurrency.code, sylius.localeCode) }}
                                    </span>

                                    {% if discount %}
                                        {% set discountedPrice = (defaultVariant.channelPricings.first.price * (100 - discount) / 100)|round %}
                                        <span class="ui small green text">
                                            {{ discountedPrice|sylius_format_money(sylius.channel.baseCurrency.code, sylius.localeCode) }}
                                        </span>
                                    {% endif %}
                                {% endif %}
                            </div>
                        </div>

                        <div class="extra content">
                            <div class="ui checkbox">
                                <input type="checkbox"
                                       checked
                                       data-abderrahimghazali--sylius-upsell-plugin--fbt-target="checkbox"
                                       data-action="change->abderrahimghazali--sylius-upsell-plugin--fbt#toggle"
                                       data-variant-code="{{ defaultVariant.code|default('') }}"/>
                                <label>{{ 'upsell.shop.add_this_item'|trans }}</label>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>

        <div class="ui hidden divider"></div>

        <button class="ui primary button"
                data-abderrahimghazali--sylius-upsell-plugin--fbt-target="button"
                data-action="click->abderrahimghazali--sylius-upsell-plugin--fbt#addAllToCart">
            <i class="cart plus icon"></i>
            {{ 'upsell.shop.add_items_to_cart'|trans({'%count%': fbtProducts|length}) }}
            (<span data-abderrahimghazali--sylius-upsell-plugin--fbt-target="count">{{ fbtProducts|length }}</span>)
        </button>

        <div class="alert alert-success d-none mt-3" data-abderrahimghazali--sylius-upsell-plugin--fbt-target="confirmation">
            {{ 'upsell.shop.added_to_cart'|trans }}
        </div>
    </div>
{% endif %}
