{
    "name": "abderrahimghazali/sylius-upsell-plugin",
    "type": "sylius-plugin",
    "description": "Post-purchase upsell and cross-sell plugin for Sylius 2.x — Frequently Bought Together, one-click add-all-to-cart",
    "license": "MIT",
    "keywords": ["sylius", "sylius-plugin", "upsell", "cross-sell", "frequently-bought-together", "ecommerce"],
    "homepage": "https://github.com/abderrahimghazali/sylius-upsell-plugin",
    "authors": [
        {
            "name": "Abderrahim Ghazali",
            "homepage": "https://github.com/abderrahimghazali"
        }
    ],
    "support": {
        "issues": "https://github.com/abderrahimghazali/sylius-upsell-plugin/issues",
        "source": "https://github.com/abderrahimghazali/sylius-upsell-plugin"
    },
    "require": {
        "php": "^8.2",
        "doctrine/orm": "^2.17 || ^3.0",
        "sylius/sylius": "^2.1",
        "symfony/cache": "^7.0",
        "symfony/framework-bundle": "^7.0",
        "symfony/stimulus-bundle": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "Abderrahim\\SyliusUpsellPlugin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Abderrahim\\SyliusUpsellPlugin\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "branch-alias": {
            "dev-main": "2.0-dev"
        }
    },
    "config": {
        "sort-packages": true
    }
}
